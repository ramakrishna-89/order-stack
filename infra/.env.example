# Postgres
POSTGRES_DB=ecom
POSTGRES_USER=ecom
POSTGRES_PASSWORD=ecom123

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@ecom.dev
PGADMIN_DEFAULT_PASSWORD=admin123

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# Traefik — dashboard BasicAuth (htpasswd format)
# Generate with: htpasswd -nbB <username> <password>
DASHBOARD_AUTH=admin:$$2y$$05$$cYrFgnLadTntXe83KFFIBuHJJS711crBE7D.5NxzkZufbgqr..X.u

# Docker socket — override if your Docker Desktop uses a non-standard path
# macOS Docker Desktop: /Users/<you>/.docker/run/docker.sock
# Linux / standard:     /var/run/docker.sock  (default, no need to set)
DOCKER_SOCK=/var/run/docker.sock
