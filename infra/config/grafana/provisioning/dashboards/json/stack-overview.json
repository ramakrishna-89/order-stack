{
  "title": "Stack Overview",
  "uid": "stack-overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Orders / sec",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/orders\",method=\"POST\"}[1m]))",
        "legendFormat": "orders/sec"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":50},{"color":"red","value":100}] } } }
    },
    {
      "type": "stat",
      "title": "HTTP p95 Latency",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/orders\"}[1m])) by (le))",
        "legendFormat": "p95"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":0.5},{"color":"red","value":1}] } } }
    },
    {
      "type": "stat",
      "title": "HTTP Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count[1m])) * 100",
        "legendFormat": "error %"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":1},{"color":"red","value":5}] } } }
    },
    {
      "type": "stat",
      "title": "Kafka Consumer Lag",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(kafka_consumergroup_lag * on(consumergroup) group_left() (kafka_consumergroup_members > 0))",
        "legendFormat": "lag"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":100},{"color":"red","value":1000}] } } }
    },
    {
      "type": "timeseries",
      "title": "Orders / sec (service)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/orders\",method=\"POST\",status=~\"2..\"}[30s]))",
          "legendFormat": "success"
        },
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/orders\",method=\"POST\",status=~\"4..|5..\"}[30s]))",
          "legendFormat": "errors"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "Traefik — req/sec by router",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "uid": "prometheus" },
          "expr": "sum by (router) (rate(traefik_router_requests_total{router=~\".+@file\"}[30s]))",
          "legendFormat": "{{router}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "Kafka Consumer Lag (live)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [{
        "datasource": { "uid": "prometheus" },
        "expr": "sum(kafka_consumergroup_lag * on(consumergroup) group_left() (kafka_consumergroup_members > 0)) by (consumergroup)",
        "legendFormat": "{{consumergroup}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "logs",
      "title": "Service Logs (live)",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [{
        "datasource": { "uid": "loki" },
        "expr": "{service=~\"order-service|notification-service\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
